# ==============================================================================
# DebianXRDP-Pro
# Git Ignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local

# Keep the example file
!.env.example

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
*.out
*.err

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.cache
*.pid
*.bak
*.old
*.orig
*~

# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------
.directory

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store

# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# IDE
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.venv/
venv/

# ------------------------------------------------------------------------------
# Node.js
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------------------------------
dist/
build/
coverage/

# ------------------------------------------------------------------------------
# Archives
# ------------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.7z

