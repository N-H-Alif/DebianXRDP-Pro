# ==============================================================================
# DebianXRDP-Pro
# Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# User Configuration
# ------------------------------------------------------------------------------

USERNAME=debian
PASSWORD=ChangeMe123!

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------

TZ=UTC

# ------------------------------------------------------------------------------
# Locale
# ------------------------------------------------------------------------------

LANG=en_US.UTF-8
LANGUAGE=en_US:en
LC_ALL=en_US.UTF-8

# ------------------------------------------------------------------------------
# Desktop Resolution
# ------------------------------------------------------------------------------

DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080
DISPLAY_DEPTH=24

# ------------------------------------------------------------------------------
# XRDP
# ------------------------------------------------------------------------------

XRDP_PORT=3389

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------

ALLOW_ROOT_LOGIN=false

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Health Check
# ------------------------------------------------------------------------------

HEALTHCHECK_ENABLED=true

# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------

SESSION_TYPE=xfce

# ------------------------------------------------------------------------------
# User IDs
# ------------------------------------------------------------------------------

USER_UID=1000
USER_GID=1000

# ------------------------------------------------------------------------------
# Future Features (Do Not Modify Yet)
# ------------------------------------------------------------------------------

INSTALL_CHROMIUM=true
INSTALL_WINE=true
INSTALL_NODEJS=true
INSTALL_PHP=true
INSTALL_JAVA=true
INSTALL_DOCKER_CLI=false
AUTO_UPDATE=false
